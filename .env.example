# Обязательно: ключ API от proxyapi.ru.
PROXY_API_KEY=your_proxy_api_key_here

# Обязательно: токен Telegram-бота от BotFather или из Telegram-эмулятора.
BOT_TOKEN=your_telegram_bot_token_here

# Опционально: endpoint API для Telegram-эмулятора.
# Для обычного Telegram оставьте пустым.
BOT_BASE_URL=http://localhost:3001

# Опционально: endpoint файлов API для эмулятора.
# Для обычного Telegram оставьте пустым.
BOT_BASE_FILE_URL=http://localhost:3001
